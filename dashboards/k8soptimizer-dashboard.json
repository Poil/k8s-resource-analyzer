            "desc": true,
            "displayName": "CPU Max (Cores)"
          }
        ]
      },
      "pluginVersion": "12.3.1",
      "targets": [
        {
          "expr": "avg(avg_over_time(kube_workload_container_resource_usage_cpu_cores_avg{cluster=~\"$cluster\", namespace=~\"$namespace\", workload=~\"$workload\", container=~\"$container\"}[$long_period])) by (cluster, namespace, workload, container)",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "max(max_over_time(kube_workload_container_resource_usage_cpu_cores_max{cluster=~\"$cluster\", namespace=~\"$namespace\", workload=~\"$workload\", container=~\"$container\"}[$long_period])) by (cluster, namespace, workload, container)",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "max by (cluster, namespace, workload, container) (kube_pod_container_resource_requests{resource=\"cpu\", cluster=~\"$cluster\", namespace=~\"$namespace\", container=~\"$container\"} * on(cluster, namespace, pod) group_left(workload) max by (cluster, namespace, pod, workload) (namespace_workload_pod:kube_pod_owner:relabel{cluster=~\"$cluster\", namespace=~\"$namespace\"}))",
          "format": "table",
          "instant": true,
          "refId": "REQ_CPU"
        },
        {
          "expr": "max by (cluster, namespace, workload, container) (kube_pod_container_resource_limits{resource=\"cpu\", cluster=~\"$cluster\", namespace=~\"$namespace\", container=~\"$container\"} * on(cluster, namespace, pod) group_left(workload) max by (cluster, namespace, pod, workload) (namespace_workload_pod:kube_pod_owner:relabel{cluster=~\"$cluster\", namespace=~\"$namespace\"}))",
          "format": "table",
          "instant": true,
          "refId": "E"
        },
        {
          "expr": "avg(avg_over_time(kube_workload_container_resource_usage_memory_bytes_avg{cluster=~\"$cluster\", namespace=~\"$namespace\", workload=~\"$workload\", container=~\"$container\"}[$long_period])) by (cluster, namespace, workload, container)",
          "format": "table",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "max(max_over_time(kube_workload_container_resource_usage_memory_bytes_max{cluster=~\"$cluster\", namespace=~\"$namespace\", workload=~\"$workload\", container=~\"$container\"}[$long_period])) by (cluster, namespace, workload, container)",
          "format": "table",
          "instant": true,
          "refId": "D"
        },
        {
          "expr": "max by (cluster, namespace, workload, container) (kube_pod_container_resource_requests{resource=\"memory\", cluster=~\"$cluster\", namespace=~\"$namespace\", container=~\"$container\"} * on(cluster, namespace, pod) group_left(workload) max by (cluster, namespace, pod, workload) (namespace_workload_pod:kube_pod_owner:relabel{cluster=~\"$cluster\", namespace=~\"$namespace\"}))",
          "format": "table",
          "instant": true,
          "refId": "REQ_MEM"
        },
        {
          "expr": "max by (cluster, namespace, workload, container) (kube_pod_container_resource_limits{resource=\"memory\", cluster=~\"$cluster\", namespace=~\"$namespace\", container=~\"$container\"} * on(cluster, namespace, pod) group_left(workload) max by (cluster, namespace, pod, workload) (namespace_workload_pod:kube_pod_owner:relabel{cluster=~\"$cluster\", namespace=~\"$namespace\"}))",
          "format": "table",
          "instant": true,
          "refId": "F"
        }
      ],
      "title": "Historical CPU & Memory Baseline ($long_period)",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "CPU Req/Max Ratio",
            "binary": {
              "left": "Value #REQ_CPU",
              "operator": "/",
              "right": "Value #B"
            },
            "mode": "binary",
            "reduce": {
              "reducer": "sum"
            }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "Mem Req/Max Ratio",
            "binary": {
              "left": "Value #REQ_MEM",
              "operator": "/",
              "right": "Value #D"
            },
            "mode": "binary",
            "reduce": {
              "reducer": "sum"
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "Value #A": "CPU Avg (Cores)",
              "Value #B": "CPU Max (Cores)",
              "Value #C": "Memory Avg",
              "Value #D": "Memory Max",
              "Value #E": "CPU Limit (Cores)",
              "Value #F": "Memory Limit",
              "Value #REQ_CPU": "CPU Request",
              "Value #REQ_MEM": "Memory Request"
            }
          }
        }
      ],
      "type": "table"
    },
