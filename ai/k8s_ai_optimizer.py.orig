#!/usr/bin/env python3
# flake8: noqa: E501
# pylint: disable=line-too-long
# ruff: noqa: E501

import os
import json
import requests
from google import genai

# ==========================================
# Configuration
# ==========================================
PROMETHEUS_URL = "http://localhost:9090" # Replace with your actual Prometheus endpoint
GEMINI_API_KEY = os.environ.get("GEMINI_API_KEY")
LONG_PERIOD = "7d"

# ==========================================
# 1. Prometheus Query Helper
# ==========================================
def query_prometheus(query):
    """Executes a PromQL query against the Prometheus API."""
    try:
        response = requests.get(
            f"{PROMETHEUS_URL}/api/v1/query",
            params={'query': query}
        )
        response.raise_for_status()
        return response.json().get('data', {}).get('result', [])
    except Exception as e:
        print(f"Error querying Prometheus for '{query}': {e}")
        return []

# ==========================================
# 2. Fetch Metrics (Now grouping by Cluster!)
# ==========================================
def gather_cluster_metrics():
    print("Gathering CPU and Memory metrics per Cluster from Prometheus...")
    metrics_data = {}

    # Query 1: Max CPU Usage over the period
    cpu_max_query = f'max(max_over_time(kube_workload_container_resource_usage_cpu_cores_max[{LONG_PERIOD}])) by (cluster, namespace, workload, container)'
    for result in query_prometheus(cpu_max_query):
        labels = result['metric']
        key = f"{labels.get('cluster')}/{labels.get('namespace')}/{labels.get('workload')}/{labels.get('container')}"
        if key not in metrics_data: metrics_data[key] = {"labels": labels}
        metrics_data[key]["cpu_max_cores"] = round(float(result['value'][1]), 4)

    # Query 2: Current CPU Requests (FIXED: Using Grafana group_left join)
    cpu_req_query = """
    max by (cluster, namespace, workload, container) (
      kube_pod_container_resource_requests{resource="cpu"}
      * on(cluster, namespace, pod) group_left(workload)
      label_replace(
        max by (cluster, namespace, pod) (kube_pod_info),
        "workload", "$1", "pod", "^(.*?)(?:-[0-9a-f]{7,10}-[0-9a-z]{5}|-[0-9a-z]{5}|-[0-9]+)?$"
      )
    )
    """
    for result in query_prometheus(cpu_req_query):
        labels = result['metric']
        key = f"{labels.get('cluster')}/{labels.get('namespace')}/{labels.get('workload')}/{labels.get('container')}"
        if key in metrics_data:
            metrics_data[key]["cpu_request_cores"] = round(float(result['value'][1]), 4)

    # Query 3: Max Memory Usage over the period
    mem_max_query = f'max(max_over_time(kube_workload_container_resource_usage_memory_bytes_max[{LONG_PERIOD}])) by (cluster, namespace, workload, container)'
    for result in query_prometheus(mem_max_query):
        labels = result['metric']
        key = f"{labels.get('cluster')}/{labels.get('namespace')}/{labels.get('workload')}/{labels.get('container')}"
        if key not in metrics_data: metrics_data[key] = {"labels": labels}
        metrics_data[key]["memory_max_mib"] = round(float(result['value'][1]) / (1024 * 1024), 2)

    # Query 4: Current Memory Requests (FIXED: Using Grafana group_left join)
    mem_req_query = """
    max by (cluster, namespace, workload, container) (
      kube_pod_container_resource_requests{resource="memory"}
      * on(cluster, namespace, pod) group_left(workload)
      label_replace(
        max by (cluster, namespace, pod) (kube_pod_info),
        "workload", "$1", "pod", "^(.*?)(?:-[0-9a-f]{7,10}-[0-9a-z]{5}|-[0-9a-z]{5}|-[0-9]+)?$"
      )
    )
    """
    for result in query_prometheus(mem_req_query):
        labels = result['metric']
        key = f"{labels.get('cluster')}/{labels.get('namespace')}/{labels.get('workload')}/{labels.get('container')}"
        if key in metrics_data:
            metrics_data[key]["memory_request_mib"] = round(float(result['value'][1]) / (1024 * 1024), 2)

    # Query 5: OOM Killed Events
    oom_query = 'max by (cluster, namespace, workload, container) (kube_workload_container_resource_usage_memory_oom_killed)'
    for result in query_prometheus(oom_query):
        labels = result['metric']
        key = f"{labels.get('cluster')}/{labels.get('namespace')}/{labels.get('workload')}/{labels.get('container')}"
        if key in metrics_data:
            metrics_data[key]["oom_kill_events"] = int(result['value'][1])

    return metrics_data


# ==========================================
# 3. Ask Gemini for Recommendations
# ==========================================
def get_ai_recommendations(metrics_data):
    if not GEMINI_API_KEY:
        print("Error: GEMINI_API_KEY environment variable not set.")
        return

    client = genai.Client(api_key=GEMINI_API_KEY)

    # ADDED 'Cluster' TO THE CSV HEADER
    csv_lines = ["Cluster,Namespace,Workload,Container,CPU_Max,CPU_Req,Mem_Max_MiB,Mem_Req_MiB,OOM_Kills"]
    skipped_count = 0

    for key, data in metrics_data.items():
        raw_cpu_req = data.get("cpu_request_cores", 0.0)
        raw_mem_req = data.get("memory_request_mib", 0.0)

        try:
            cpu_req = float(raw_cpu_req) if raw_cpu_req else 0.0
            mem_req = float(raw_mem_req) if raw_mem_req else 0.0
        except ValueError:
            cpu_req = 0.0
            mem_req = 0.0

        # FILTER: Skip containers with <= 256MiB memory OR <= 0.050 CPU
        if mem_req <= 256.0 and cpu_req <= 0.050:
            skipped_count += 1
            continue

        labels = data.get("labels", {})
        cluster = labels.get("cluster", "N/A")
        ns = labels.get("namespace", "N/A")
        wl = labels.get("workload", "N/A")
        c = labels.get("container", "N/A")

        cpu_max = data.get("cpu_max_cores", "")
        mem_max = data.get("memory_max_mib", "")
        oom_kills = data.get("oom_kill_events", 0)

        # Build the line with the cluster variable
        line = f"{cluster},{ns},{wl},{c},{cpu_max},{cpu_req},{mem_max},{mem_req},{oom_kills}"
        csv_lines.append(line)

    csv_payload = "\n".join(csv_lines)
    containers_to_analyze = len(csv_lines) - 1

    prompt = f"""
    You are an expert Kubernetes administrator and cloud cost optimization specialist.
    I have extracted container resource usage metrics from multiple clusters over the last {LONG_PERIOD}.
    I have already pre-filtered this list to only include significant workloads.

    Here is the telemetry data in CSV format:
    {csv_payload}

    Please analyze this data and provide recommendations for tuning BOTH CPU and Memory.

    Rules for your recommendations:
    1. Memory is provided in MiB. Always suggest memory limits/requests in MiB or GiB.
    2. CPU is provided in cores.
    3. Memory Tuning: If a container has OOM kills (>0), aggressively recommend raising the memory limit. If max memory usage is consistently far below the requested memory, recommend lowering the request to save node capacity.
    4. CPU Tuning: Identify over-provisioned CPU requests vs max usage and recommend reductions.

    CRITICAL INSTRUCTIONS:
    1. Analyze the data but ONLY output the Top 10 most critical containers that need tuning (prioritize highest wasted cost / over-provisioning, or highest OOM kill risk).
    2. Format your entire response as a SINGLE Markdown table. Do not write introductory or concluding paragraphs.
    3. Use the following columns: Cluster | Namespace | Workload | Container | New CPU Req | New Mem Limit | Reason
    4. Keep the 'Reason' column to a maximum of 5 words (e.g., "Severely over-provisioned CPU", or "High OOM risk").

    Format your response as a clear, scannable report grouped FIRST by Cluster, and THEN by Workload. Include a short explanation for each recommendation.
    """

    print(f"\nOptimization Stats:")
    print(f"- Skipped {skipped_count} tiny containers.")
    print(f"- Sending {containers_to_analyze} significant containers to Gemini for analysis...\n")

    if containers_to_analyze == 0:
        print("No containers met the minimum resource thresholds. Exiting.")
        return

    # Use generate_content_stream instead!
    response = client.models.generate_content_stream(
        model='gemini-2.5-flash',
        contents=prompt,
    )

    print("\n--- AI Recommendations ---")
    for chunk in response:
        print(chunk.text, end="", flush=True)
    print("\n--------------------------")


# ==========================================
# Execution
# ==========================================
if __name__ == "__main__":
    k8s_data = gather_cluster_metrics()

    if not k8s_data:
        print("No metrics gathered. Please check your Prometheus URL and queries.")
    else:
        # We send everything that passes the filter!
        get_ai_recommendations(k8s_data)
